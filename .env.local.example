# ── Booking Form Email (Nodemailer) ─────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# In Vercel: add these under Project → Settings → Environment Variables.

# SMTP server settings
# Gmail: host=smtp.gmail.com, port=587
# Outlook/Hotmail: host=smtp-mail.outlook.com, port=587
# Custom/Mailgun/Sendgrid: use their SMTP credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Your sending email address (must match the SMTP account)
SMTP_USER=you@gmail.com

# Gmail: use an App Password (not your regular password)
# Generate one at: myaccount.google.com/apppasswords
# (Requires 2FA enabled on your Google account)
SMTP_PASS=your-app-password-here

# Where new booking notifications are sent (your business email)
OWNER_EMAIL=info@hibachiconnect.com
